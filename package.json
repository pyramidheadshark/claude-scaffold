{
  "name": "opencode-scaffold",
  "version": "2.0.0",
  "description": "CLI tool that bootstraps a powerful agentic environment for OpenCode — agents, skills, memory-bank, pre-commit hooks, MCP servers",
  "main": "dist/index.js",
  "files": [
    "dist",
    "scripts"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup src/index.ts --format esm --watch",
    "start": "node dist/index.js",
    "test": "vitest run tests/e2e/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyramidheadshark/opencode-scaffold.git"
  },
  "keywords": [
    "opencode",
    "ai-agents",
    "scaffold",
    "cli",
    "llm",
    "developer-tools",
    "mcp",
    "pre-commit",
    "ai-workflow"
  ],
  "author": "pyramidheadshark",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/pyramidheadshark/opencode-scaffold/issues"
  },
  "homepage": "https://github.com/pyramidheadshark/opencode-scaffold#readme",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "inquirer": "^13.4.2",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "@types/sqlite3": "^3.1.11",
    "execa": "^9.6.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "type": "module",
  "bin": {
    "opencode-scaffold": "dist/index.js"
  }
}